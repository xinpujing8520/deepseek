---
layout: layouts/base.njk
pagination:
  data: collections
  size: 1
  alias: tag
  filter:
    - all
    - nav
    - post
    - posts
    - article
    - articles
permalink: /tags/{{ tag | tagSlug }}/index.html
eleventyComputed:
  title: "DeepSeek {{ tag }} Tags"
  description: "DeepSeek {{ tag }} 相关实操内容集合。"
---
<section class="page-hero">
  <div class="container">
    <p class="eyebrow">Tags</p>
    <h1>DeepSeek {{ tag }} 内容集合</h1>
    <p class="tagline">围绕同一主题整理的文章，适合连续阅读。</p>
  </div>
</section>

<section class="section">
  <div class="container toc-list">
    {% for post in collections[tag] | reverse %}
    <article class="toc-card">
      <img src="{{ post.data.cover }}" alt="{{ post.data.title }} 配图" width="240" height="160" loading="lazy">
      <div>
        <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
        <p>{{ post.data.description }}</p>
        <p class="meta">{{ post.date | readableDate }}</p>
      </div>
    </article>
    {% endfor %}
  </div>
</section>
